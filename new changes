Private Sub UpdateTarget(sourceFiles() As Variant, targetWS As Worksheet, folder As String, logWS As Worksheet)
    ' Uniform logic: Clear data rows 2+ (preserve header), paste data from each source A2+ vertically starting at A2, no blanks
    Dim oldRows As Long
    oldRows = GetLastRow(targetWS, "A") - 1  ' Exclude header
    
    ' Clear data rows (use ClearContents to avoid #REF)
    If oldRows > 0 Then
        Dim dataRange As Range
        Set dataRange = targetWS.Range(targetWS.Cells(2, 1), targetWS.Cells(targetWS.Rows.Count, targetWS.Columns.Count))
        dataRange.ClearContents
    End If
    
    Dim pasteRow As Long: pasteRow = 2
    Dim totalNewRows As Long
    Dim i As Integer
    For i = LBound(sourceFiles) To UBound(sourceFiles)
        Dim srcPath As String: srcPath = folder & sourceFiles(i)
        Dim srcWB As Workbook: Set srcWB = Workbooks.Open(srcPath, ReadOnly:=True)
        Dim srcWS As Worksheet: Set srcWS = srcWB.Sheets(1)
        
        Dim srcLastRow As Long: srcLastRow = GetLastRow(srcWS, "A")
        If srcLastRow > 1 Then  ' Has data
            Dim srcLastCol As Long: srcLastCol = GetLastColumn(srcWS)
            Dim srcDataRng As Range
            Set srcDataRng = srcWS.Range(srcWS.Cells(2, 1), srcWS.Cells(srcLastRow, srcLastCol))
            srcDataRng.Copy
            targetWS.Cells(pasteRow, 1).PasteSpecial Paste:=xlPasteValues
            totalNewRows = totalNewRows + srcDataRng.Rows.Count
            pasteRow = pasteRow + srcDataRng.Rows.Count
        End If
        
        srcWB.Close SaveChanges:=False
    Next i
    
    Application.CutCopyMode = False
    AppendLog logWS, Format(Date, "dd-mm-yyyy"), Format(Time, "hh:mm:ss"), targetWS.Name, oldRows, totalNewRows, "Success"
End Sub

Private Function GetLastRow(ws As Worksheet, col As String) As Long
    GetLastRow = ws.Cells(ws.Rows.Count, col).End(xlUp).Row
End Function

Private Function GetLastColumn(ws As Worksheet) As Long
    GetLastColumn = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
End Function

Private Sub AppendLog(logWS As Worksheet, logDate As String, logTime As String, target As String, oldRec As Long, newRec As Long, status As String)
    Dim nextRow As Long: nextRow = GetLastRow(logWS, "A") + 1
    With logWS
        .Cells(nextRow, 1).Value = logDate
        .Cells(nextRow, 2).Value = logTime
        .Cells(nextRow, 3).Value = target
        .Cells(nextRow, 4).Value = oldRec
        .Cells(nextRow, 5).Value = newRec
        .Cells(nextRow, 6).Value = status
    End With
End Sub

Private Function SheetExists(wb As Workbook, sheetName As String) As Boolean
    On Error Resume Next
    SheetExists = Not wb.Sheets(sheetName) Is Nothing
    On Error GoTo 0
End Function

Private Function FileExists(path As String) As Boolean
    FileExists = Dir(path) <> ""
End Function
